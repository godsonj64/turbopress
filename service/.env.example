# Copy to service/.env and fill in. All values have safe dev defaults.

# Core
DEBUG=true
# "inline" = in-process dev runner (no GPU); "modal" = serverless GPU worker.
RUNNER=inline
DATABASE_URL=sqlite+aiosqlite:///./turbopress.db
# In production (Neon): postgresql+asyncpg://USER:PASS@HOST/db?sslmode=require
PIPELINE_VERSION=0.3.0
PUBLIC_BASE_URL=http://localhost:8000

# Certificate signing (Ed25519). Generate a stable key with:
#   python -c "from turbopress.certificate import generate_signing_key as g; print(g()[0])"
# Publish the corresponding public key. Empty => ephemeral dev key at startup.
SIGNING_PRIVATE_KEY_B64=

# Worker callback auth (shared secret between control plane and GPU worker).
WORKER_CALLBACK_SECRET=change-me

# Stripe metered billing (empty => billing disabled / free).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
REQUIRE_BILLING_FOR_PUBLIC_MODELS=false

# Cloudflare R2 (S3-compatible). Empty => artifact storage disabled.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=turbopress-artifacts
R2_PRESIGN_TTL_SECONDS=3600

# Modal
MODAL_APP_NAME=turbopress-worker
MODAL_FUNCTION_NAME=compress_job
